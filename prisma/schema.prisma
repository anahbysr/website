generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  description     String?
  price           Float
  salePrice       Float?
  badge           String?
  allowCustomization Boolean   @default(false)
  customizationLabel String?
  customizationHelp  String?
  status          String      @default("DRAFT")
  images          String
  sizes           String      @map("stock")
  collectionId    String?
  collection      Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  collectionOrder Int         @default(0)
  fabric          String      @default("Cotton")
  ageFrom         Int         @default(0)
  ageTo           Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  reviews         Review[]
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  coverImage  String?   @map("heroImage")
  order       Int       @default(0) @map("sortOrder")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model Order {
  id                String   @id @default(uuid())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  address           String?
  items             String
  total             Float
  status            String   @default("PENDING")
  trackingNumber    String?
  courier           String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orderNumber       String?  @unique
  razorpayOrderId   String?
  razorpayPaymentId String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  pincode           String?
  subtotal          Float?
  shippingCharge    Float?
  couponCode        String?
  discount          Float    @default(0)
  paymentMethod     String?
  confirmationEmailSentAt DateTime?
  reviews           Review[]
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  author    String   @map("customerName")
  city      String?
  rating    Int
  body      String   @map("text")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model InstagramCache {
  id        Int      @id @default(1)
  posts     String // JSON array of 6 posts
  fetchedAt DateTime @default(now())
}

model Settings {
  key   String @id
  value String
}
